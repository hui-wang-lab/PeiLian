# PeiLian 环境变量模板
# 拷贝为 .env 后填入真实值；.env 不会进版本管理。

# OpenAI 兼容 API 的密钥（必填，除非用 --skip-llm 跑 demo）
OPENAI_API_KEY=

# OpenAI 兼容 API 的 base_url
# 官方：https://api.openai.com/v1
# 国内代理 / Azure / DeepSeek 等可填各自的 OpenAI-兼容端点
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认调用的模型名（按所选提供商调整）
OPENAI_MODEL=gpt-4o-mini
